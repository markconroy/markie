   * {@inheritdoc}
   */
  public function speechToText(string|SpeechToTextInput $input, string $model_id, array $tags = []): SpeechToTextOutput {
    $this->loadClient();

    try {
      // @todo Implement actual API call to your provider.
      throw new AiResponseErrorException('Speech-to-text not yet implemented.');
    }
    catch (\Exception $e) {
      throw new AiResponseErrorException($e->getMessage());
