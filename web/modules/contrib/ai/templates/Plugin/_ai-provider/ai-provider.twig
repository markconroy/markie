{% endif %}
  /**
   * Loads the API client.
   */
  protected function loadClient(): void {
    if ($this->client) {
      return;
    }

    // @todo Initialize your API client here.
    // Example: $this->client = new YourApiClient($this->loadApiKey());
  }

}
