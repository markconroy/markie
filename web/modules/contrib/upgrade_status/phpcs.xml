<?xml version="1.0" encoding="UTF-8"?>
<ruleset name="upgrade_status">
  <rule ref="Drupal"/>
  <rule ref="DrupalPractice"/>

  <!-- The project key is intentionally present in these test module info files
       to simulate contrib projects for testing purposes. -->
  <rule ref="Drupal.InfoFiles.AutoAddedKeys.Project">
    <exclude-pattern>tests/modules/upgrade_status_test_contrib_error/upgrade_status_test_contrib_error.info.yml</exclude-pattern>
    <exclude-pattern>tests/modules/upgrade_status_test_contrib_11_compatible/upgrade_status_test_contrib_11_compatible.info.yml</exclude-pattern>
  </rule>
</ruleset>
